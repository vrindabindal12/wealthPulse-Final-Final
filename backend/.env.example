# ── Copy this file to .env and fill in the real values ──────────────────────

# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379

# Clerk Authentication (Get these from the Clerk Dashboard)
CLERK_API_URL=https://your-clerk-domain.clerk.accounts.dev
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# External APIs
GROQ_API_KEY=your_groq_key
GEMINI_API_KEY=your_gemini_key
FINNHUB_API_KEY=your_finnhub_key

# CORS — set this to your real Vercel deployment URL or local frontend address
FRONTEND_URL=http://localhost:3000
